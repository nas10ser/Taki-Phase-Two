# ============================================================
#  TAKI Bot — متغيّرات البيئة (انسخ هذا الملف إلى ‎.env‎ واملأ القيم)
#  cp .env.example .env   ثم ضع رموزك (tokens) مكان القيم الفارغة.
#  لا ترفع ملف ‎.env‎ إلى GitHub أبداً (مُستثنى تلقائياً).
# ============================================================

# --- قاعدة البيانات (Supabase) — إلزامي ---
# من Supabase ▸ Project Settings ▸ API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- تيليجرام — إلزامي لتشغيل بوت تيليجرام ---
# 1) افتح @BotFather في تيليجرام ▸ /newbot ▸ اتبع الخطوات ▸ انسخ الـToken
TELEGRAM_BOT_TOKEN=
# 2) رمز سرّي تختاره أنت (أي نص عشوائي طويل) لحماية الـwebhook
TELEGRAM_WEBHOOK_SECRET=

# --- واتساب Cloud API — اختياري (اتركه فارغاً إن لم تستخدم واتساب الآن) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- عنوان الموقع العام (يُستخدم في روابط البوت) ---
APP_URL=https://taki-test-eight.vercel.app

# --- منفذ التشغيل (اتركه فارغاً — المنصّات تضبطه تلقائياً) ---
PORT=8080
