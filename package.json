{
  "name": "TAKI",
  "version": "7.2.0",
  "description": "TAKI — discount booking platform (React 18 + Parcel 2 + Supabase, Node 24)",
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "scripts": {
    "start": "parcel index.html --public-url / --host 0.0.0.0 --port 3000",
    "dev": "parcel index.html --public-url / --host 0.0.0.0 --port 3000",
    "build": "parcel build index.html --public-url / && cp -f robots.txt sitemap.xml og-image.png logo192.png logo512.png dist/ 2>/dev/null; cp -R models dist/models 2>/dev/null || true",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .parcel-cache dist",
    "postinstall": "node scripts/strip-tfjs-maps.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@parcel/packager-raw-url": "^2.16.4",
    "@parcel/transformer-webmanifest": "^2.16.4",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "buffer": "^6.0.3",
    "parcel": "^2.16.4",
    "postcss": "^8.5.14",
    "process": "^0.11.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sentry/react": "^8.55.2",
    "@supabase/supabase-js": "^2.45.0",
    "@tensorflow/tfjs": "^4.22.0",
    "clsx": "^2.1.1",
    "jsqr": "^1.4.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^5.3.4",
    "tailwind-merge": "^2.5.0"
  }
}
